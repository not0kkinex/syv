        except PermissionError as e:
            log_error("CONFIG", f"Cannot write syv.json (permission denied)", {"path": config_path, "error": str(e)}, "Check directory permissions", exit_code=13)
        except OSError as e:
            log_error("CONFIG", f"Cannot write syv.json (disk full?)", {"path": config_path, "error": str(e)}, "Free up disk space and retry", exit_code=13)
