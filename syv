# --- Custom Exception Hierarchy ---
class SYVException(Exception):
    def __init__(self, message, operation=None, target=None, details=None, recovery=None, exit_code=1):
        self.operation = operation
        self.target = target
        self.details = details
        self.recovery = recovery
        self.exit_code = exit_code
        super().__init__(message)

    def formatted(self):
        lines = [
            f"[!] {self.operation or 'SYV Error'}",
            f" |- Operation: {self.operation or 'N/A'}",
            f" |- Error Type: {type(self).__name__} ({self.args[0] if self.args else 'Unknown'})",
        ]
        if self.target:
            lines.append(f" |- Target: {self.target}")
        if self.details:
            lines.append(f" |- Details: {self.details}")
        if self.recovery:
            lines.append(f" |- Suggested fix: {self.recovery}")
        lines.append(f" \\- Exit Code: {self.exit_code}")
        return "\n".join(lines)

class ConfigError(SYVException):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('operation', 'Configuration Validation')
        kwargs.setdefault('exit_code', 2)
        super().__init__(message, **kwargs)

class FileSystemError(SYVException):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('operation', 'File System Operation')
        kwargs.setdefault('exit_code', 13)
        super().__init__(message, **kwargs)

class NetworkError(SYVException):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('operation', 'Network Request')
        kwargs.setdefault('exit_code', 3)
        super().__init__(message, **kwargs)

class SYVNetworkTimeoutError(NetworkError):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('details', 'Connection timed out - server may be overloaded or unreachable')
        kwargs.setdefault('recovery', 'Check server status, increase timeout, or retry later')
        super().__init__(message, **kwargs)

class SYVConnectionRefusedError(NetworkError):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('details', 'Connection refused - no server listening on target port')
        kwargs.setdefault('recovery', 'Verify the server is running and the port is correct')
        super().__init__(message, **kwargs)

class SYVSSRFRiskError(NetworkError):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('operation', 'SSRF Prevention')
        kwargs.setdefault('details', 'Target URL is not localhost-bound - blocking to prevent SSRF attack')
        kwargs.setdefault('recovery', 'Only URLs pointing to 127.0.0.1 or localhost are allowed')
        kwargs.setdefault('exit_code', 7)
        super().__init__(message, **kwargs)

class SecurityError(SYVException):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('operation', 'Security Check')
        kwargs.setdefault('exit_code', 7)
        super().__init__(message, **kwargs)

class ResourceError(SYVException):
    def __init__(self, message, **kwargs):
        kwargs.setdefault('operation', 'Resource Management')
        kwargs.setdefault('exit_code', 8)
        super().__init__(message, **kwargs)


