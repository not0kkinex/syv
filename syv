        log_info("Would generate syv.json configuration template.")

def clean_system(target_dir):
    log_sys(f"Initiating clean sweep on '{target_dir}' and './syv_cache'...")
    deleted_files = 0
    try:
        if os.path.exists("./syv_cache"):
            if not DRY_RUN_MODE:
                if os.path.islink("./syv_cache"):
                    raise SecurityError("Refusing to remove symlinked cache directory", target="./syv_cache", recovery="Remove the symlink manually if intended")
                shutil.rmtree("./syv_cache")
            log_info("Purged ./syv_cache directory.")
    except PermissionError as e:
        log_error("CLEAN", f"Cannot remove syv_cache (permission denied)", {"path": "./syv_cache", "error": str(e)}, "Check file ownership or run with appropriate permissions", exit_code=13)
    except SecurityError as e:
        log_warn(e.formatted())
    if os.path.exists(target_dir):
        try:
            validate_directory_readable(target_dir)
        except (FileSystemError, SecurityError) as e:
            log_warn(e.formatted())
            return
        for root, dirs, files in os.walk(target_dir):
            for file in files:
                if file.endswith('.gz') or file == "build_manifest.json":
                    filepath = os.path.join(root, file)
                    if not DRY_RUN_MODE:
                        try:
                            if os.path.islink(filepath):
                                log_debug(f"Skipping symlink: {filepath}")
                                continue
                            os.remove(filepath)
                        except PermissionError as e:
                            log_error("CLEAN", f"Cannot remove {filepath} (permission denied)", {"error": str(e)}, f"Check permissions: chmod 644 {filepath}", exit_code=13)
                            continue
                        except OSError as e:
                            log_error("CLEAN", f"Cannot remove {filepath}", {"error": str(e)}, "Check if file is in use by another process", exit_code=13)
                            continue
                    deleted_files += 1
                    log_debug(f"Deleted: {filepath}")
    log_info(f"Clean sweep complete. Removed {deleted_files} optimization artifacts.")


# --- MODULE 1: SPA Build Optimizer ---
def is_ignored(filepath):
    for ignore_pattern in CONFIG.get("ignore", []):
        if ignore_pattern in filepath.split(os.sep):
            return True
    return False

def generate_file_hash(filepath):
    hasher = hashlib.md5()
    try:
        with open(filepath, 'rb') as afile:
            buf = afile.read()
            hasher.update(buf)
    except PermissionError as e:
        raise FileSystemError(f"Cannot read file (permission denied): {filepath}", target=filepath, details=str(e), recovery=f"Check file permissions: chmod 644 {filepath}")
    except OSError as e:
        raise FileSystemError(f"Cannot read file: {filepath}", target=filepath, details=str(e), recovery="Check if file exists and is accessible")
    return hasher.hexdigest()[:8]

def process_single_file(filepath):
    start_time = time.time()
    try:
        validate_directory_readable(os.path.dirname(filepath) or ".")
    except (FileSystemError, SecurityError) as e:
        log_warn(e.formatted())
        return {}, 0
    file_hash = generate_file_hash(filepath)
    filename = os.path.basename(filepath)
    manifest_entry = {filename: f"{filename}?v={file_hash}"}
    try:
        with open(filepath, 'rb') as f_in:
            original_data = f_in.read()
            original_size = len(original_data)
    except PermissionError as e:
        raise FileSystemError(f"Cannot read file (permission denied): {filepath}", target=filepath, details=str(e), recovery=f"chmod 644 {filepath}")
    except OSError as e:
        raise FileSystemError(f"Cannot read file: {filepath}", target=filepath, details=str(e), recovery="Check if file exists and is accessible")
    gz_filepath = filepath + '.gz'
    compressed_size = original_size
    if not DRY_RUN_MODE:
        try:
            with gzip.open(gz_filepath, 'wb') as f_out:
                f_out.write(original_data)
            compressed_size = os.path.getsize(gz_filepath)
        except PermissionError as e:
            raise FileSystemError(f"Cannot write compressed file (permission denied): {gz_filepath}", target=gz_filepath, details=str(e), recovery=f"chmod +w {os.path.dirname(gz_filepath)}")
        except OSError as e:
            if e.errno == errno.ENOSPC:
                try:
                    free = shutil.disk_usage(os.path.dirname(gz_filepath) or ".").free
                except OSError:
                    free = 0
                needed = len(original_data)
                raise FileSystemError(f"Disk full while writing {gz_filepath}", target=gz_filepath, details=f"Need ~{needed} bytes, only {free} available", recovery="Free up disk space or reduce file sizes")
            raise FileSystemError(f"Failed to write compressed file: {gz_filepath}", target=gz_filepath, details=str(e), recovery="Check disk space and permissions")
    saved_bytes = original_size - compressed_size
    log_debug(f"Processed {filename} in {(time.time() - start_time)*1000:.2f}ms (Saved {saved_bytes} bytes)")
    return manifest_entry, saved_bytes

def compress_payloads(target_dir):
    log_sys(f"Scanning directory: {target_dir}")
    if not os.path.exists(target_dir):
        log_error("BUILD", f"Target directory not found: {target_dir}", recovery=f"Create the directory or specify a valid path: syv build ./dist", exit_code=1)
        sys.exit(1)
    try:
        validate_directory_readable(target_dir)
    except (FileSystemError, SecurityError) as e:
        log_warn(e.formatted())
        sys.exit(1)
    files_to_process = []
    for root, dirs, files in os.walk(target_dir):
        dirs[:] = [d for d in dirs if not is_ignored(os.path.join(root, d))]
        for file in files:
            if file.endswith('.js') or file.endswith('.css'):
                files_to_process.append(os.path.join(root, file))
    total_files = len(files_to_process)
    if total_files == 0:
        log_warn("No target files found to compress.")
        return
    log_info(f"Discovered {total_files} payloads. Engaging multi-core compression...")
    manifest = {}
    total_saved_bytes = 0
    completed_files = 0
    cpu_count = os.cpu_count() or 4
    optimal_threads = min(cpu_count, 16)
    t_start = time.time()
    try:
        with concurrent.futures.ThreadPoolExecutor(max_workers=optimal_threads) as executor:
            future_to_file = {executor.submit(process_single_file, filepath): filepath for filepath in files_to_process}
            print_progress(0, total_files)
            for future in concurrent.futures.as_completed(future_to_file):
                try:
                    manifest_entry, saved_bytes = future.result()
                    manifest.update(manifest_entry)
                    total_saved_bytes += saved_bytes
                    completed_files += 1
                    print_progress(completed_files, total_files)
                except FileSystemError as exc:
                    log_error("BUILD", str(exc), {"file": future_to_file[future]}, exc.recovery, exc.exit_code)
                except Exception as exc:
                    log_error("BUILD", f"Unexpected thread failure", {"file": future_to_file.get(future, "unknown"), "error": str(exc)}, "Check file integrity and permissions", exit_code=1)
    except MemoryError:
        log_error("BUILD", "Out of memory - too many threads or large files", {"threads": optimal_threads, "files": total_files}, "Reduce the number of concurrent workers or file sizes", exit_code=8)
        if total_files > 0:
            log_sys("Falling back to sequential processing...")
            for filepath in files_to_process:
                try:
                    manifest_entry, saved_bytes = process_single_file(filepath)
                    manifest.update(manifest_entry)
                    total_saved_bytes += saved_bytes
                    completed_files += 1
                    print_progress(completed_files, total_files)
                except Exception as exc:
                    log_error("BUILD", f"Sequential processing failed", {"file": filepath, "error": str(exc)}, "", exit_code=1)
    if not DRY_RUN_MODE:
        manifest_path = os.path.join(target_dir, "build_manifest.json")
        try:
            validate_manifest_keys(manifest)
            with open(manifest_path, 'w', encoding='utf-8') as mf:
                json.dump(manifest, mf, indent=4)
        except SecurityError as e:
            log_error("BUILD", str(e), {"manifest": manifest_path}, e.recovery, e.exit_code)
        except PermissionError as e:
            log_error("BUILD", f"Cannot write manifest (permission denied)", {"path": manifest_path, "error": str(e)}, f"chmod +w {target_dir}", exit_code=13)
        rewrite_html_dom(target_dir)
    else:
        rewrite_html_dom(target_dir)
    log_info(f"SPA Protocol Complete in {time.time() - t_start:.2f}s. Saved {total_saved_bytes / 1024 / 1024:.2f} MB.")


# --- MODULE 1.5: DOM Rewriter ---
def read_file_with_fallback(filepath):
    encodings = ['utf-8', 'latin-1', 'cp1252', 'iso-8859-1']
    for encoding in encodings:
        try:
            with open(filepath, 'r', encoding=encoding) as f:
                return f.read()
        except UnicodeDecodeError:
            continue
        except PermissionError as e:
            raise FileSystemError(f"Cannot read file (permission denied): {filepath}", target=filepath, details=str(e), recovery=f"chmod 644 {filepath}")
        except OSError as e:
            raise FileSystemError(f"Cannot read file: {filepath}", target=filepath, details=str(e), recovery="Check if file exists and is accessible")
    raise FileSystemError(f"Cannot decode file with any supported encoding: {filepath}", target=filepath, details="Tried: utf-8, latin-1, cp1252, iso-8859-1", recovery="Convert the file to UTF-8 encoding")

def rewrite_html_dom(target_dir):
    log_sys("Initiating DOM Rewriter protocol...")
    manifest_path = os.path.join(target_dir, "build_manifest.json")
    if not os.path.exists(manifest_path):
        log_warn("No build_manifest.json found. Skipping HTML injection.")
        return
    try:
        with open(manifest_path, 'r', encoding='utf-8') as mf:
            manifest = json.load(mf)
        validate_manifest_keys(manifest)
    except json.JSONDecodeError as e:
        log_error("DOM", f"Invalid manifest JSON at line {e.lineno}", {"path": manifest_path, "error": str(e)}, "Fix the build_manifest.json file", exit_code=2)
        return
    except SecurityError as e:
        log_error("DOM", str(e), {"manifest": manifest_path}, e.recovery, e.exit_code)
        return
    injected_count = 0
    for root, dirs, files in os.walk(target_dir):
        dirs[:] = [d for d in dirs if not is_ignored(os.path.join(root, d))]
        for file in files:
            if file.endswith('.html'):
                filepath = os.path.join(root, file)
                try:
                    content = read_file_with_fallback(filepath)
                except FileSystemError as e:
                    log_warn(e.formatted())
                    continue
                original = content
                for orig, vers in manifest.items():
                    safe_orig = re.escape(orig)
                    pattern = r'((?:src|href)=["\'][^"\']*?)(' + safe_orig + r')(["\'])'
                    content = re.sub(pattern, r'\g<1>' + vers + r'\g<3>', content)
                if content != original:
                    if not DRY_RUN_MODE:
                        try:
                            with open(filepath, 'w', encoding='utf-8') as f:
                                f.write(content)
                        except PermissionError as e:
                            log_error("DOM", f"Cannot write HTML file (permission denied)", {"path": filepath, "error": str(e)}, f"chmod +w {filepath}", exit_code=13)
                            continue
                        except OSError as e:
                            log_error("DOM", f"Cannot write HTML file", {"path": filepath, "error": str(e)}, "Check disk space and permissions", exit_code=13)
                            continue
                    injected_count += 1
                    log_debug(f"Injected cache-busting hashes into: {file}")
    log_info(f"DOM Rewrite Complete. Updated {injected_count} HTML files.")


# --- MODULE 1B: Watch Mode Daemon ---
def watch_payloads(target_dir):
    log_sys(f"Initializing Watch Daemon on: {target_dir}")
    if not os.path.exists(target_dir):
        log_error("WATCH", f"Target directory not found: {target_dir}", recovery=f"Create the directory or specify a valid path: syv watch ./dist", exit_code=1)
        sys.exit(1)
    try:
        validate_directory_readable(target_dir)
    except (FileSystemError, SecurityError) as e:
        log_warn(e.formatted())
        sys.exit(1)
    file_states = {}
    MAX_WATCHED_FILES = 100000
    manifest_path = os.path.join(target_dir, "build_manifest.json")
    manifest = {}
    cleanup_counter = 0
    if os.path.exists(manifest_path) and not DRY_RUN_MODE:
        try:
            with open(manifest_path, 'r', encoding='utf-8') as mf:
                manifest = json.load(mf)
        except (json.JSONDecodeError, PermissionError) as e:
            log_warn(f"Could not load existing manifest: {e}")
    log_info("Watching for file changes... (Press Ctrl+C to exit)")
    try:
        while True:
            try:
                for root, dirs, files in os.walk(target_dir):
                    dirs[:] = [d for d in dirs if not is_ignored(os.path.join(root, d))]
                    for file in files:
                        if file.endswith('.js') or file.endswith('.css'):
                            filepath = os.path.join(root, file)
                            try:
                                mtime = os.path.getmtime(filepath)
                            except OSError:
                                continue
                            if filepath not in file_states:
                                if len(file_states) >= MAX_WATCHED_FILES:
                                    log_warn(f"Watch limit reached ({MAX_WATCHED_FILES} files).")
                                    continue
                                file_states[filepath] = mtime
                            elif file_states[filepath] < mtime:
                                log_info(f"Change detected: {file}")
                                file_states[filepath] = mtime
                                try:
                                    manifest_entry, _ = process_single_file(filepath)
                                    manifest.update(manifest_entry)
                                except (FileSystemError, OSError) as e:
                                    log_error("WATCH", f"Failed to process changed file", {"file": filepath, "error": str(e)}, "Check file permissions", exit_code=13)
                                    continue
                                if not DRY_RUN_MODE:
                                    try:
                                        validate_manifest_keys(manifest)
                                        with open(manifest_path, 'w', encoding='utf-8') as mf:
                                            json.dump(manifest, mf, indent=4)
                                    except (SecurityError, PermissionError) as e:
                                        log_warn(f"Could not update manifest: {e}")
                                log_sys("Cache updated and manifest rewritten.")
                cleanup_counter += 1
                if cleanup_counter % 60 == 0 and len(file_states) > 10000:
                    current_files = set()
                    for root, dirs, files in os.walk(target_dir):
                        for f in files:
                            current_files.add(os.path.join(root, f))
                    stale_count = 0
                    for fp in list(file_states.keys()):
                        if fp not in current_files:
                            del file_states[fp]
                            stale_count += 1
                    if stale_count:
                        log_debug(f"Cleaned {stale_count} stale entries from watch state")
            except OSError as e:
                log_error("WATCH", f"File system error during watch", {"error": str(e)}, "Check disk health and permissions", exit_code=13)
                time.sleep(5)
                continue
            time.sleep(1)
    except KeyboardInterrupt:
        print(f"\n{C_ORANGE}Watch daemon terminated.{C_RESET}")
        sys.exit(0)


# --- MODULE 2: SSG Cache Warmer ---
def write_html_manifest(cache_dir, byte_size, status):
    manifest_path = os.path.join(cache_dir, "manifest.json")
    metadata = {
        "generated_at": int(time.time()),
        "byte_size": byte_size,
        "status": status,
        "generator": "SYV-Terminal-CLI/5.0"
    }
    try:
        with open(manifest_path, "w", encoding='utf-8') as f:
            json.dump(metadata, f, indent=4)
    except PermissionError as e:
        log_error("CACHE", f"Cannot write cache manifest (permission denied)", {"path": manifest_path, "error": str(e)}, f"chmod +w {cache_dir}", exit_code=13)
    except OSError as e:
        log_error("CACHE", f"Cannot write cache manifest", {"path": manifest_path, "error": str(e)}, "Check disk space", exit_code=13)

def is_cache_stale(cache_dir):
    manifest_path = os.path.join(cache_dir, "manifest.json")
    index_path = os.path.join(cache_dir, "index.html")
    if not os.path.exists(manifest_path) or not os.path.exists(index_path):
        return True
    try:
        with open(manifest_path, 'r', encoding='utf-8') as f:
            meta = json.load(f)
        generated_at = meta.get("generated_at", 0)
        ttl = CONFIG.get("ttl", 3600)
        age = int(time.time()) - generated_at
        log_debug(f"Cache age: {age}s / TTL: {ttl}s")
        return age > ttl
    except json.JSONDecodeError as e:
        log_warn(f"Cache manifest has invalid JSON: {e}")
        return True
    except PermissionError as e:
        log_warn(f"Cannot read cache manifest: {e}")
        return True
    except Exception as e:
        log_warn(f"Could not read cache manifest: {e}")
        return True

@with_retry(max_retries=3, base_delay=1, exceptions=(urllib.error.URLError, socket.timeout, ConnectionError))
def fetch_url_with_retry(url, timeout=10):
    req = urllib.request.Request(url, headers={'User-Agent': 'SYV-Terminal-CLI/5.0'})
    with urllib.request.urlopen(req, timeout=timeout) as response:
        return response.read(), response.getcode()

def fetch_single_route(url, base_cache_dir):
    start_time = time.time()
    try:
        validate_url_safe(url)
        try:
            html, status = fetch_url_with_retry(url)
        except urllib.error.HTTPError as e:
            status = e.code
            html = b""
            if e.code == 404:
                log_warn(f"Route not found (404): {url}")
            elif e.code == 500:
                log_warn(f"Server error (500): {url} - the application may be crashing")
            elif e.code == 503:
                log_warn(f"Service unavailable (503): {url} - server is overloaded or down for maintenance")
            else:
                log_warn(f"HTTP {e.code} for {url}")
        except urllib.error.URLError as e:
            reason = e.reason
            if isinstance(reason, ConnectionRefusedError):
                raise SYVConnectionRefusedError(f"Connection refused for {url}", target=url, recovery="Start the local server or check if port is correct")
            elif isinstance(reason, socket.timeout) or isinstance(reason, TimeoutError):
                raise SYVNetworkTimeoutError(f"Connection timed out for {url}", target=url, recovery="Check server load or increase timeout")
            else:
                raise NetworkError(f"Network error for {url}: {reason}", target=url, recovery="Check network connectivity and DNS resolution")
        except socket.timeout:
            raise SYVNetworkTimeoutError(f"Connection timed out for {url}", target=url, recovery="Check server load or increase timeout")
        except TimeoutError:
            raise SYVNetworkTimeoutError(f"Connection timed out for {url}", target=url, recovery="Check server load or increase timeout")
        parsed = urlparse(url)
        route_path = parsed.path.strip("/")
        if not route_path:
            target_dir = base_cache_dir
            filename = "index.html"
        elif route_path.endswith(".html"):
            target_dir = os.path.join(base_cache_dir, os.path.dirname(route_path))
            filename = os.path.basename(route_path)
        else:
            target_dir = os.path.join(base_cache_dir, route_path)
            filename = "index.html"
        if not DRY_RUN_MODE:
            try:
                validate_directory_writable(target_dir)
            except (FileSystemError, SecurityError) as e:
                log_warn(e.formatted())
                return len(html) if html else 0, status if status else 500
            filepath = os.path.join(target_dir, filename)
            try:
                if os.path.islink(filepath):
                    raise SecurityError(f"Refusing to write to symlink target: {filepath}", target=filepath, recovery="Remove the symlink and retry")
                with open(filepath, "wb") as f:
                    f.write(html)
            except SecurityError as e:
                log_warn(e.formatted())
                return 0, 500
            except PermissionError as e:
                log_error("SCRAPE", f"Cannot write cache file (permission denied)", {"path": filepath, "error": str(e)}, f"chmod +w {target_dir}", exit_code=13)
                return 0, 500
            except OSError as e:
                if e.errno == errno.ENOSPC:
                    log_error("SCRAPE", f"Disk full", {"path": filepath}, "Free up disk space", exit_code=13)
                else:
                    log_error("SCRAPE", f"Cannot write cache file", {"path": filepath, "error": str(e)}, "Check disk space and permissions", exit_code=13)
                return 0, 500
        log_debug(f"Scraped {url} -> {filename} in {(time.time() - start_time)*1000:.2f}ms")
        return len(html) if html else 0, status if status else 200
    except SYVException as e:
        log_error(type(e).__name__.upper(), str(e), {"url": url}, e.recovery, e.exit_code)
        return 0, 500
    except Exception as e:
        log_error("SCRAPE", f"Unexpected error scraping {url}", {"error": str(e)}, "Check the target server and network connectivity", exit_code=1)
        return 0, 500

def scrape_localhost(port, is_forced):
    base_url = f"http://127.0.0.1:{port}"
    cache_dir = os.path.abspath("./syv_cache")
    if not is_forced and not is_cache_stale(cache_dir):
        log_sys(f"Cache is still fresh. Skipping rebuild. (Use 'force run update' to override)")
        return
    log_sys(f"{'FORCE OVERRIDE: ' if is_forced else ''}Warming HTML protocol for: {base_url}")
    t_start = time.time()
    urls_to_scrape = [base_url]
    try:
        sitemap_url = f"{base_url}/sitemap.xml"
        try:
            sitemap_data, sitemap_status = fetch_url_with_retry(sitemap_url, timeout=5)
            if sitemap_status == 200:
                try:
                    sitemap_text = sitemap_data.decode('utf-8')
                    locs = re.findall(r'<loc>(.*?)</loc>', sitemap_text)
                    if locs:
                        urls_to_scrape = [loc.strip() for loc in locs]
                        log_info(f"Sitemap.xml detected. Found {len(urls_to_scrape)} routes to render.")
                    else:
                        log_debug("Sitemap.xml found but no <loc> entries detected.")
                except UnicodeDecodeError:
                    log_debug("Sitemap.xml has non-UTF-8 encoding. Trying latin-1 fallback.")
                    try:
                        sitemap_text = sitemap_data.decode('latin-1')
                        locs = re.findall(r'<loc>(.*?)</loc>', sitemap_text)
                        if locs:
                            urls_to_scrape = [loc.strip() for loc in locs]
                            log_info(f"Sitemap.xml detected. Found {len(urls_to_scrape)} routes to render.")
                    except Exception:
                        log_debug("Could not decode sitemap.xml. Defaulting to single-page / route.")
            else:
                log_debug(f"Sitemap.xml returned HTTP {sitemap_status}. Defaulting to single-page / route.")
        except (urllib.error.HTTPError, urllib.error.URLError, socket.timeout, TimeoutError, ConnectionError):
            log_debug("No sitemap.xml found. Defaulting to single-page / route.")
    except Exception:
        log_debug("No sitemap.xml found. Defaulting to single-page / route.")
    total_bytes = 0
    total_urls = len(urls_to_scrape)
    completed = 0
    successful_pages = 0
    cpu_count = os.cpu_count() or 4
    optimal_threads = min(cpu_count, 16)
    try:
        with concurrent.futures.ThreadPoolExecutor(max_workers=optimal_threads) as executor:
            future_to_url = {executor.submit(fetch_single_route, url, cache_dir): url for url in urls_to_scrape}
            print_progress(0, total_urls, prefix="Scraping")
            for future in concurrent.futures.as_completed(future_to_url):
                try:
                    b_size, status = future.result()
                    if status == 200:
                        successful_pages += 1
                    total_bytes += b_size
                    completed += 1
                    print_progress(completed, total_urls, prefix="Scraping")
                except Exception as exc:
                    log_error("SCRAPE", f"Thread failed", {"url": future_to_url.get(future, "unknown"), "error": str(exc)}, "", exit_code=1)
    except MemoryError:
        log_error("SCRAPE", "Out of memory - too many concurrent requests", {"threads": optimal_threads, "urls": total_urls}, "Reduce thread count or process fewer URLs", exit_code=8)
        log_sys("Falling back to sequential scraping...")
        for url in urls_to_scrape:
            b_size, status = fetch_single_route(url, cache_dir)
            if status == 200:
                successful_pages += 1
            total_bytes += b_size
            completed += 1
            print_progress(completed, total_urls, prefix="Scraping")
    if successful_pages == 0 and total_urls > 0 and not DRY_RUN_MODE:
        log_error("SCRAPE", "All requested routes returned errors (404/500)", {"total_urls": total_urls, "cache_dir": cache_dir}, "Ensure the target server is running and routes are valid", exit_code=3)
        sys.exit(1)
    if not DRY_RUN_MODE and total_bytes > 0:
        write_html_manifest(cache_dir, total_bytes, 200)
    log_info(f"SSG Protocol Complete. Cached {successful_pages}/{total_urls} pages ({total_bytes / 1024:.2f} KB) in {time.time() - t_start:.2f}s")


# --- Router Logic ---
def extract_port(args):
    port = CONFIG.get("port", 8080)
    raw_port_str = None
    if "--port" in args:
        idx = args.index("--port")
        if idx + 1 < len(args):
            raw_port_str = args[idx + 1]
    elif "-p" in args:
        idx = args.index("-p")
        if idx + 1 < len(args):
            raw_port_str = args[idx + 1]
    if raw_port_str is not None:
        try:
            port = int(raw_port_str)
        except ValueError:
            log_error("CONFIG", f"Invalid port value: '{raw_port_str}'", {"port": raw_port_str, "type": type(raw_port_str).__name__}, "Specify a valid integer port (e.g., --port 8080)", exit_code=2)
            return port
        try:
            validate_port(port)
        except ConfigError as e:
            log_warn(e.formatted())
    return port

def print_help():
    print(f"\n{C_GREEN}SYV / UNIFIED OPTIMIZATION DAEMON v5.1{C_RESET}")
    print("Usage: syv [COMMAND] [OPTIONS]\n")
    print("Commands:")
    print("  init                  Generate a default syv.json configuration.")
    print("  start                 Initialize the system daemon.")
    print("  build [dir]           Multi-thread compress & hash JS/CSS payloads.")
    print("  watch [dir]           Live-monitor [dir] and recompile on file save.")
    print("  clean [dir]           Purge all .gz files, manifests, and syv_cache.")
    print("  run update            Scrape localhost (and sitemap.xml) to generate SSG cache.")
    print("  force run update      Bypass TTL and force a complete HTML rebuild.\n")
    print("Options:")
    print("  -p, --port <number>   Target localhost port.")
    print("  --debug               Enable verbose millisecond execution logging.")
    print("  --dry-run             Simulate actions without writing/deleting any files.\n")

def main():
    global DEBUG_MODE, DRY_RUN_MODE
    args = sys.argv[1:]
    if "--debug" in args:
        DEBUG_MODE = True
        args.remove("--debug")
        log_debug("Debug mode engaged. Verbose logging enabled.")
    if "--dry-run" in args:
        DRY_RUN_MODE = True
        args.remove("--dry-run")
        log_sys("DRY-RUN MODE ENGAGED: No files will be modified.")
    load_config()
    if not args or args[0] in ["help", "-h", "--help"]:
        print_help()
        sys.exit(0)
    command = args[0]
    port = extract_port(args)
    try:
        if command == "init":
            sys_init()
        elif command == "start":
            sys_start()
        elif command == "clean":
            clean_system(args[1] if len(args) > 1 else "./dist")
        elif command == "build":
            compress_payloads(args[1] if len(args) > 1 else "./dist")
        elif command == "watch":
            watch_payloads(args[1] if len(args) > 1 else "./dist")
        elif command == "force" and len(args) >= 3 and args[1] == "run" and args[2] == "update":
            scrape_localhost(port, is_forced=True)
        elif command == "run" and len(args) >= 2 and args[1] == "update":
            scrape_localhost(port, is_forced=False)
        else:
            log_warn(f"Unrecognized command '{' '.join(args)}'.")
            print_help()
            sys.exit(1)
    except KeyboardInterrupt:
        print(f"\n{C_ORANGE}Execution interrupted.{C_RESET}")
        sys.exit(0)
    except SYVException as e:
        log_error(type(e).__name__.upper(), str(e), {"target": e.target, "details": e.details} if e.details else {"target": e.target} if e.target else None, e.recovery, e.exit_code)
        sys.exit(e.exit_code)
    except Exception as e:
        log_error("FATAL", f"Unexpected execution error", {"error": str(e), "trace": traceback.format_exc()}, "Report this issue at https://github.com/kyrtstn/syv/issues", exit_code=1)
        sys.exit(1)

if __name__ == "__main__":
    main()
