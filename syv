#!/usr/bin/env python3
import sys
import time
import os
import json
import gzip
import hashlib
import urllib.request
import urllib.error
import concurrent.futures
from datetime import datetime

# --- Cyber-Security Terminal Aesthetics ---
C_GREEN = '\033[92m'
C_ORANGE = '\033[93m'
C_CYAN = '\033[96m'
C_RESET = '\033[0m'
C_DARK_GREY = '\033[90m'

def log_info(msg):
    print(f"{C_DARK_GREY}[{C_GREEN}+{C_DARK_GREY}]{C_RESET} {msg}")

def log_warn(msg):
    print(f"{C_DARK_GREY}[{C_ORANGE}!{C_DARK_GREY}]{C_RESET} {C_ORANGE}{msg}{C_RESET}")

def log_sys(msg):
    print(f"{C_DARK_GREY}[{C_CYAN}~{C_DARK_GREY}]{C_RESET} {C_CYAN}{msg}{C_RESET}")

def print_progress(current, total, prefix='Optimizing', length=30):
    """Prints a dynamic, self-updating progress bar on a single terminal line."""
    percent = ("{0:.1f}").format(100 * (current / float(total)))
    filled_length = int(length * current // total)
    bar = '█' * filled_length + '-' * (length - filled_length)
    
    # \r returns the carriage to the start of the line, \033[K clears the line
    sys.stdout.write(f'\r\033[K{C_DARK_GREY}[{C_CYAN}~{C_DARK_GREY}]{C_RESET} {prefix} |{C_GREEN}{bar}{C_RESET}| {percent}% [{current}/{total}]')
    sys.stdout.flush()
    if current == total:
        sys.stdout.write('\n')

# --- Help Menu ---
def print_help():
    print(f"\n{C_GREEN}SYV / UNIFIED OPTIMIZATION DAEMON v3.5 (MULTI-THREADED){C_RESET}")
    print(f"{C_CYAN}======================================================={C_RESET}")
    print("Usage: syv [COMMAND] [OPTIONS]\n")
    print("Core Commands:")
    print("  start                 Initialize the system daemon.")
    print("  help, -h, --help      Display this help menu.\n")
    print("SSG Caching Commands:")
    print("  run update            Run standard HTML cache update on localhost.")
    print("  force run update      Bypass TTL and force a complete HTML rebuild.")
    print("  -p, --port <number>   Target localhost port (Default: 8080).\n")
    print("SPA Build Commands:")
    print("  build [directory]     Compress & hash JS/CSS payloads using all CPU cores.\n")
    print(f"{C_ORANGE}Examples:{C_RESET}")
    print("  syv force run update -p 3000")
    print("  syv build ./frontend/dist\n")

# --- Core Setup ---
def sys_start():
    log_info("Initializing syv system daemon...")
    time.sleep(0.3)
    log_sys("Environment paths & CPU cores verified.")
    log_info("Daemon ready. Awaiting operational commands.")

# --- MODULE 1: SPA Build Optimizer (MULTI-THREADED) ---
def generate_file_hash(filepath):
    """Generates an MD5 hash of a file for cache-busting."""
    hasher = hashlib.md5()
    with open(filepath, 'rb') as afile:
        buf = afile.read()
        hasher.update(buf)
    return hasher.hexdigest()[:8]

def process_single_file(filepath):
    """Thread-safe function to hash and compress a single file."""
    # 1. Generate Cache-Busting Hash
    file_hash = generate_file_hash(filepath)
    filename = os.path.basename(filepath)
    manifest_entry = {filename: f"{filename}?v={file_hash}"}
    
    # 2. Compress the file
    with open(filepath, 'rb') as f_in:
        original_data = f_in.read()
        original_size = len(original_data)
    
    gz_filepath = filepath + '.gz'
    with gzip.open(gz_filepath, 'wb') as f_out:
        f_out.write(original_data)
    
    compressed_size = os.path.getsize(gz_filepath)
    saved_bytes = original_size - compressed_size
    
    return manifest_entry, saved_bytes

def compress_payloads(target_dir):
    """Scans for JS/CSS files and parallel-processes them using thread pools."""
    log_sys(f"Scanning target directory: {target_dir}")
    
    if not os.path.exists(target_dir):
        log_warn(f"Directory '{target_dir}' not found. Run this in your project root.")
        return

    # Phase 1: Gather files
    files_to_process = []
    for root, dirs, files in os.walk(target_dir):
        for file in files:
            if file.endswith('.js') or file.endswith('.css'):
                files_to_process.append(os.path.join(root, file))
                
    total_files = len(files_to_process)
    if total_files == 0:
        log_warn("No .js or .css files found to compress.")
        return

    log_info(f"Discovered {total_files} payloads. Engaging multi-core compression engine...")
    
    manifest = {}
    total_saved_bytes = 0
    completed_files = 0

    # Phase 2: Multi-threaded execution
    # Determine optimal threads based on CPU cores, defaulting to 4 if indeterminate
    optimal_threads = os.cpu_count() or 4 
    
    with concurrent.futures.ThreadPoolExecutor(max_workers=optimal_threads) as executor:
        # Map the function to the files
        future_to_file = {executor.submit(process_single_file, filepath): filepath for filepath in files_to_process}
        
        # Initial progress bar render
        print_progress(0, total_files, prefix="Compressing")
        
        for future in concurrent.futures.as_completed(future_to_file):
            try:
                manifest_entry, saved_bytes = future.result()
                manifest.update(manifest_entry)
                total_saved_bytes += saved_bytes
                
                # Update progress bar
                completed_files += 1
                print_progress(completed_files, total_files, prefix="Compressing")
            except Exception as exc:
                # To prevent progress bar breaking, print errors nicely
                sys.stdout.write(f"\n{C_ORANGE}[!] File generated an exception: {exc}{C_RESET}\n")

    # Phase 3: Write manifest and finish
    manifest_path = os.path.join(target_dir, "build_manifest.json")
    with open(manifest_path, 'w') as mf:
        json.dump(manifest, mf, indent=4)
        
    log_sys(f"Build manifest written to {manifest_path}")
    log_info(f"SPA Protocol Complete. Optimized {total_files} files, saving {total_saved_bytes / 1024 / 1024:.2f} MB.")

# --- MODULE 2: SSG Cache Warmer ---
def write_manifest(cache_dir, byte_size, status):
    """Writes a machine-readable manifest for the HTML backend to parse."""
    manifest_path = os.path.join(cache_dir, "manifest.json")
    metadata = {
        "generated_at": int(time.time()),
        "timestamp_human": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "byte_size": byte_size,
        "status": status,
        "generator": "SYV-Terminal-CLI/3.5"
    }
    with open(manifest_path, "w") as f:
        json.dump(metadata, f, indent=4)
    log_sys(f"HTML Cache Manifest written to {manifest_path}")

def scrape_localhost(port, is_forced):
    url = f"http://127.0.0.1:{port}"
    cache_dir = os.path.abspath("./syv_cache")
    
    if is_forced:
        log_warn(f"FORCE OVERRIDE: Executing hard HTML rebuild against {url}")
    else:
        log_sys(f"Initiating HTML warming protocol for: {url}")
        
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'SYV-Terminal-CLI/3.5'})
        with urllib.request.urlopen(req, timeout=5) as response:
            html = response.read()
            status = response.getcode()
            byte_size = len(html)
            
            if not os.path.exists(cache_dir):
                os.makedirs(cache_dir)
                log_sys(f"Constructing new cache directory at {cache_dir}")
                
            cache_file = os.path.join(cache_dir, "index.html")
            with open(cache_file, "wb") as f:
                f.write(html)
                
            write_manifest(cache_dir, byte_size, status)
                
            log_info(f"Response [{status} OK]: Extracted {byte_size / 1024:.2f} KB.")
            log_info(f"Static HTML payload successfully locked.")
            
    except urllib.error.URLError as e:
        log_warn(f"Connection Failed: Could not hit {url}.")
        if hasattr(e, 'reason'):
            log_warn(f"Socket Reason: {e.reason} - Verify port {port} is active.")
    except Exception as e:
        log_warn(f"Unhandled Exception: {e}")

def sys_run(target_func, is_forced, port):
    if target_func == "update":
        scrape_localhost(port, is_forced)
    elif target_func == "-func-":
        log_sys("Executing placeholder [-func-] protocol...")
        time.sleep(0.4)
        log_info("Protocol [-func-] executed cleanly.")
    else:
        log_warn(f"Target function '{target_func}' missing from routing table.")

# --- Router Logic ---
def extract_port(args):
    port = "8080" # Default port
    if "--port" in args:
        idx = args.index("--port")
        if idx + 1 < len(args): port = args[idx + 1]
    elif "-p" in args:
        idx = args.index("-p")
        if idx + 1 < len(args): port = args[idx + 1]
    return port

def main():
    args = sys.argv[1:]

    if not args or args[0] in ["help", "-h", "--help"]:
        print_help()
        sys.exit(0)

    command = args[0]
    port = extract_port(args)

    try:
        if command == "start":
            sys_start()
            
        elif command == "build":
            target_dir = args[1] if len(args) > 1 else "./dist"
            compress_payloads(target_dir)

        elif command == "force":
            if len(args) >= 3 and args[1] == "run":
                sys_run(args[2], is_forced=True, port=port)
            else:
                log_warn("Syntax Error: syv force run <func>")
                
        elif command == "run":
            if len(args) >= 2:
                sys_run(args[1], is_forced=False, port=port)
            else:
                log_warn("Syntax Error: Missing target parameter for 'run'.")
                
        else:
            log_warn(f"Unrecognized command '{command}'.")
            
    except KeyboardInterrupt:
        print(f"\n{C_ORANGE}Execution interrupted by signal (SIGINT).{C_RESET}")
        sys.exit(0)

if __name__ == "__main__":
    main()
