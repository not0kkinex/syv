# --- Structured Error Logging ---
def log_error(category, message, context=None, recovery=None, exit_code=1):
    sys.stdout.write(f"\n{C_ORANGE}[!] {category}: {message}{C_RESET}\n")
    if context:
        for key, value in context.items():
            sys.stdout.write(f"  {C_DARK_GREY}|- {key}: {value}{C_RESET}\n")
    if recovery:
        sys.stdout.write(f"  {C_CYAN}|- Suggested fix: {recovery}{C_RESET}\n")
    if exit_code:
        sys.stdout.write(f"  {C_DARK_GREY}\\- Exit Code: {exit_code}{C_RESET}\n")


def log_info(msg):
    if CONFIG.get("silent_mode", False) and not DEBUG_MODE: return
    prefix = "[DRY-RUN] " if DRY_RUN_MODE else ""
    print(f"{C_DARK_GREY}[{C_GREEN}+{C_DARK_GREY}]{C_RESET} {C_GREEN}{prefix}{C_RESET}{msg}")

def log_warn(msg):
    prefix = "[DRY-RUN] " if DRY_RUN_MODE else ""
    print(f"{C_DARK_GREY}[{C_ORANGE}!{C_DARK_GREY}]{C_RESET} {C_ORANGE}{prefix}{msg}{C_RESET}")

def log_sys(msg):
    if CONFIG.get("silent_mode", False) and not DEBUG_MODE: return
    prefix = "[DRY-RUN] " if DRY_RUN_MODE else ""
    print(f"{C_DARK_GREY}[{C_CYAN}~{C_DARK_GREY}]{C_RESET} {C_CYAN}{prefix}{msg}{C_RESET}")

def log_debug(msg):
    if DEBUG_MODE:
        prefix = "[DRY-RUN] " if DRY_RUN_MODE else ""
        print(f"{C_DARK_GREY}[{C_MAGENTA}DEBUG{C_DARK_GREY}]{C_RESET} {C_MAGENTA}{prefix}{msg}{C_RESET}")

def print_progress(current, total, prefix='Optimizing', length=30):
    if DEBUG_MODE or CONFIG.get("silent_mode", False):
        return
    if total == 0:
        return
    percent = ("{0:.1f}").format(100 * (current / float(total)))
    filled_length = int(length * current // total)
    bar = '#' * filled_length + '-' * (length - filled_length)
    dry_tag = " (DRY-RUN)" if DRY_RUN_MODE else ""
    sys.stdout.write(f'\r\033[K{C_DARK_GREY}[{C_CYAN}~{C_DARK_GREY}]{C_RESET} {prefix}{dry_tag} |{C_GREEN}{bar}{C_RESET}| {percent}% [{current}/{total}]')
    sys.stdout.flush()
    if current == total:
        sys.stdout.write('\n')


# --- Validation & Pre-flight Checks ---
def validate_config(config):
    errors = []
    port = config.get("port", 8080)
    if not isinstance(port, int):
        errors.append(ConfigError(f"Port must be an integer, got {type(port).__name__}", target="port", recovery="Set port to a valid integer (e.g., 8080)"))
    else:
        try:
            validate_port(port)
        except ConfigError as e:
            errors.append(e)
    ttl = config.get("ttl", 3600)
    if not isinstance(ttl, int):
        errors.append(ConfigError(f"TTL must be an integer, got {type(ttl).__name__}", target="ttl", recovery="Set ttl to a valid integer (e.g., 3600)"))
    elif ttl < 0:
        errors.append(ConfigError(f"TTL cannot be negative ({ttl})", target="ttl", recovery="Set ttl to a non-negative value"))
    silent = config.get("silent_mode", False)
    if not isinstance(silent, bool):
        errors.append(ConfigError(f"silent_mode must be a boolean, got {type(silent).__name__}", target="silent_mode", recovery="Set silent_mode to true or false"))
    ignore = config.get("ignore", [])
    if not isinstance(ignore, list):
        errors.append(ConfigError(f"ignore must be a list, got {type(ignore).__name__}", target="ignore", recovery="Set ignore to a list of directory names"))
    elif not all(isinstance(i, str) for i in ignore):
        errors.append(ConfigError(f"Each ignore pattern must be a string", target="ignore", recovery="Ensure all entries in ignore are strings"))
    return errors

def validate_directory_readable(path):
    if not os.path.exists(path):
        raise FileSystemError(f"Directory does not exist: {path}", target=path, recovery=f"Create the directory: mkdir -p {path}")
    if os.path.islink(path):
        real_path = os.path.realpath(path)
        raise SecurityError(f"Path is a symlink: {path} -> {real_path}", target=path, details="Symlinks can be used for path traversal attacks", recovery=f"Use the real path directly: {real_path}")
    if not os.access(path, os.R_OK):
        raise FileSystemError(f"No read permission for directory: {path}", target=path, recovery=f"Grant read permission: chmod +r {path}")
    return True

def validate_directory_writable(path):
    if not os.path.exists(path):
        try:
            os.makedirs(path, exist_ok=True)
        except PermissionError:
            raise FileSystemError(f"Cannot create directory (permission denied): {path}", target=path, recovery=f"Check parent directory permissions or run: mkdir -p {path}")
        except OSError as e:
            raise FileSystemError(f"Cannot create directory: {path}", target=path, details=str(e), recovery=f"Check disk space and permissions")
    if os.path.islink(path):
        real_path = os.path.realpath(path)
        raise SecurityError(f"Path is a symlink: {path} -> {real_path}", target=path, details="Symlinks can be used for path traversal attacks", recovery=f"Use the real path directly: {real_path}")
    if not os.access(path, os.W_OK):
        raise FileSystemError(f"No write permission for directory: {path}", target=path, recovery=f"Grant write permission: chmod +w {path}")
    try:
        usage = shutil.disk_usage(os.path.dirname(path) or ".")
        free_bytes = usage.free
        if free_bytes < 104857600:
            free_mb = free_bytes / 1048576
            raise FileSystemError(f"Low disk space: only {free_mb:.1f} MB free", target=path, details=f"At least 100 MB recommended, {free_mb:.1f} MB available", recovery="Free up disk space or use a different drive")
    except OSError:
        pass
    return True

def validate_port(port):
    if not isinstance(port, int):
        raise ConfigError(f"Port must be an integer, got {type(port).__name__}", target="port", recovery="Specify a numeric port (e.g., --port 8080)")
    if port < 1 or port > 65535:
        raise ConfigError(f"Port {port} is out of valid range (1-65535)", target="port", recovery=f"Use a port between 1 and 65535 (suggested: 8080, 3000, 8000)")
    if port < 1024 and os.name != 'nt':
        raise ConfigError(f"Port {port} is a privileged port (< 1024)", target="port", recovery=f"Use a port >= 1024 or run with elevated privileges")
    return True

def validate_url_safe(url):
    parsed = urlparse(url)
    hostname = parsed.hostname or ""
    if hostname not in ("127.0.0.1", "localhost", "::1"):
        raise SYVSSRFRiskError(f"URL target is not localhost-bound: {url}", target=url, recovery="Only localhost URLs (127.0.0.1 or localhost) are allowed for security")
    return True

def validate_manifest_keys(manifest):
    for key in manifest:
        if ".." in key or key.startswith("/") or "~" in key:
            raise SecurityError(f"Path traversal detected in manifest key: {key}", target=key, details="Manifest keys must not contain path traversal sequences", recovery="Remove '..', '/', or '~' from manifest keys")
    return True


# --- Retry Logic ---
def with_retry(max_retries=3, base_delay=1, exceptions=(Exception,)):
    def decorator(func):
        def wrapper(*args, **kwargs):
            last_exc = None
            for attempt in range(max_retries + 1):
                try:
                    return func(*args, **kwargs)
                except exceptions as e:
                    last_exc = e
                    if attempt < max_retries:
                        delay = base_delay * (2 ** attempt)
                        log_debug(f"Retry {attempt + 1}/{max_retries} for {func.__name__} in {delay}s: {e}")
                        time.sleep(delay)
                    else:
                        log_debug(f"All {max_retries} retries exhausted for {func.__name__}: {e}")
            raise last_exc
        return wrapper
    return decorator


# --- Config & Setup ---
def load_config():
    global CONFIG
    config_path = "syv.json"
    if os.path.exists(config_path):
        try:
            with open(config_path, 'r', encoding='utf-8') as f:
                user_config = json.load(f)
            allowed_keys = {"port", "ignore", "ttl", "silent_mode"}
            for key in allowed_keys:
                if key in user_config:
                    CONFIG[key] = user_config[key]
            errors = validate_config(CONFIG)
            if errors:
                for err in errors:
                    log_warn(err.formatted())
                log_sys("Configuration has warnings - continuing with best-effort values.")
            log_sys("syv.json configuration loaded.")
            log_debug(f"Active Config: {CONFIG}")
        except json.JSONDecodeError as e:
            log_error("CONFIG", f"Failed to parse syv.json (invalid JSON at line {e.lineno}, col {e.colno})", {"path": config_path, "error": str(e)}, "Fix the JSON syntax in syv.json", exit_code=2)
        except PermissionError as e:
            log_error("CONFIG", f"Cannot read syv.json (permission denied)", {"path": config_path, "error": str(e)}, f"Check file permissions: chmod 644 {config_path}", exit_code=13)
        except Exception as e:
            log_error("CONFIG", f"Failed to read syv.json", {"path": config_path, "error": str(e)}, "Ensure syv.json exists and is readable", exit_code=1)

